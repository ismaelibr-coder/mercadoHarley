# ============================================================
# Database Configuration (MySQL)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=mercado_harley

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET=your-super-secret-key-change-this-in-production-use-strong-password
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ============================================================
# Server Configuration
# ============================================================
PORT=3001
NODE_ENV=development
# For Hostinger: use your domain/IP
FRONTEND_URL=http://localhost:5173

# ============================================================
# External APIs - Payments
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=your_mercado_pago_token_here

# ============================================================
# External APIs - Shipping
# ============================================================
MELHOR_ENVIO_TOKEN=your_melhor_envio_token_here
MELHOR_ENVIO_FROM_CEP=91030170
MELHOR_ENVIO_SANDBOX=false

# ============================================================
# External APIs - Cloud Storage
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================
# Email Service
# ============================================================
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@seudominio.com

